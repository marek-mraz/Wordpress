{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WordPress Helm Chart Values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "environment": { "type": "string" }
      }
    },
    "app": {
      "type": "object",
      "required": ["replicaCount", "image", "storage"],
      "properties": {
        "replicaCount": { "type": "integer", "minimum": 1 },
        "image": {
          "type": "object",
          "required": ["repository", "tag"],
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "busyboxImage": { "type": "string" },
        "storage": { "type": "string" },
        "storageClassName": { "type": "string" },
        "deployStrategy": { "type": "string", "enum": ["Recreate", "RollingUpdate"] },
        "resources": { "$ref": "#/$defs/resources" }
      }
    },
    "oauth": {
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "issuerUrl": { "type": "string", "format": "uri" }
      }
    },
    "database": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          }
        },
        "storage": { "type": "string" },
        "storageClassName": { "type": "string" },
        "resources": { "$ref": "#/$defs/resources" }
      }
    },
    "ingress": {
      "type": "object",
      "required": ["host"],
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string" },
        "certResolver": { "type": "string" },
        "tlsSecretName": { "type": "string" }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
        "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": "integer", "minimum": 0 }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "traefikNamespace": { "type": "string" }
      }
    },
    "sealedSecret": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "encryptedData": {
          "type": "object",
          "properties": {
            "mariadb-root-password": { "type": "string" },
            "mariadb-password": { "type": "string" },
            "wordpress-password": { "type": "string" },
            "oauth-client-secret": { "type": "string" }
          }
        }
      }
    },
    "secret": {
      "type": "object",
      "properties": {
        "mariadbRootPassword": { "type": "string" },
        "mariadbPassword": { "type": "string" },
        "wordpressPassword": { "type": "string" },
        "oauthClientSecret": { "type": "string" }
      }
    }
  },
  "$defs": {
    "resources": {
      "type": "object",
      "properties": {
        "requests": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        },
        "limits": {
          "type": "object",
          "properties": {
            "cpu": { "type": "string" },
            "memory": { "type": "string" }
          }
        }
      }
    }
  }
}
